# ─────────────────────────────────────────────
#  GAIN BLUEPRINT — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# JWT Secret (generate a random 64-char string)
JWT_SECRET=change_this_to_a_long_random_string_at_least_64_characters_long

# Admin credentials (phone + 6-digit PIN)
ADMIN_PHONE=6282253984
ADMIN_PIN=123456

# OTP settings
OTP_EXPIRY_MINUTES=5
MAX_OTP_ATTEMPTS=5

# Session duration
SESSION_DURATION_HOURS=24
ADMIN_SESSION_HOURS=8

# SMS Gateway (Fast2SMS recommended for India)
# Sign up at https://www.fast2sms.com/ to get your API key
SMS_PROVIDER=console
SMS_API_KEY=your_fast2sms_api_key_here
SMS_SENDER_ID=GAINBP

# In NODE_ENV=development, OTPs are logged to console (no SMS sent)
# In NODE_ENV=production, real SMS is sent via SMS_PROVIDER
